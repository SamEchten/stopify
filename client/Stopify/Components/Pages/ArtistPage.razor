@page "/artist"
@using Stopify.Models.Music
@using Stopify.Services.Auth
@using Stopify.Services.Music
@using Microsoft.AspNetCore.Components.Forms
@inject IAuthStateService AuthState
@inject IArtistService ArtistService
@inject IAlbumService AlbumService
@inject ISongService SongService

@if (AuthState.Role != "Artist")
{
    <div class="no-access">
        <p>This page is only available to artists.</p>
    </div>
    return;
}

<div class="hero">
    <div class="hero-content">
        <div class="hero-text">
            <h1 class="hero-title">Artist Studio</h1>
            <p class="hero-sub">@AuthState.Username</p>
        </div>
        <span class="artist-badge">Artist</span>
    </div>
</div>

<div class="studio-body">

    <!-- Create Song -->
    <section class="studio-section">
        <div class="section-header">
            <h2 class="section-title">Upload song</h2>
            <button class="green-btn" @onclick="ToggleUploadForm">
                @(showUploadForm ? "Cancel" : "+ New Song")
            </button>
        </div>

        @if (showUploadForm)
        {
            <div class="form-card">
                <div class="form-row">
                    <div class="form-field">
                        <label class="field-label">Song name</label>
                        <input class="field-input" type="text" placeholder="Enter song name..." @bind="newSongName" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-field">
                        <label class="field-label">MP3 file</label>
                        <InputFile class="file-input" accept=".mp3" OnChange="OnFileSelected" />
                    </div>
                </div>
                @if (uploadError != null)
                {
                    <p class="error-text">@uploadError</p>
                }
                @if (uploadSuccess != null)
                {
                    <p class="success-text">@uploadSuccess</p>
                }
                <button class="green-btn" @onclick="UploadSong" disabled="@isUploading">
                    @(isUploading ? "Uploading..." : "Upload")
                </button>
            </div>
        }
    </section>

    <!-- Albums -->
    <section class="studio-section">
        <div class="section-header">
            <h2 class="section-title">Albums</h2>
            <button class="green-btn" @onclick="ToggleCreateAlbum">
                @(showCreateAlbum ? "Cancel" : "+ New Album")
            </button>
        </div>

        @if (showCreateAlbum)
        {
            <div class="form-card form-card--inline">
                <input class="field-input" type="text" placeholder="Album title..." @bind="newAlbumTitle" @bind:event="oninput" @onkeydown="HandleAlbumKeyDown" />
                <button class="green-btn" @onclick="CreateAlbum" disabled="@isCreatingAlbum">
                    @(isCreatingAlbum ? "Creating..." : "Create")
                </button>
            </div>
        }

        @if (isLoading)
        {
            <p class="loading-text">Loading albums...</p>
        }
        else if (albums.Count == 0)
        {
            <p class="empty-text">No albums yet. Create your first album above.</p>
        }
        else
        {
            @foreach (var album in albums)
            {
                <div class="album-card">
                    <div class="album-header">
                        <div class="album-title-row">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" class="album-icon">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/>
                            </svg>
                            <span class="album-title">@album.Title</span>
                            <span class="song-count">@album.Songs.Count song@(album.Songs.Count != 1 ? "s" : "")</span>
                        </div>
                        <div class="album-actions">
                            <button class="add-song-btn" @onclick="() => ToggleAddSong(album.Id)" title="Add song to album">
                                + Add song
                            </button>
                            <button class="delete-album-btn" @onclick="() => DeleteAlbum(album.Id)" title="Delete album">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                                    <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    @if (addSongForAlbumId == album.Id)
                    {
                        <div class="add-song-panel">
                            <p class="add-song-label">Select a song to add:</p>
                            <div class="add-song-list">
                                @foreach (var song in allSongs.Where(s => !album.Songs.Any(as2 => as2.Id == s.Id)))
                                {
                                    <button class="add-song-item" @onclick="() => AddSongToAlbum(album.Id, song.Id)">
                                        <span>@song.Name</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="14" height="14">
                                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                                        </svg>
                                    </button>
                                }
                                @if (!allSongs.Any(s => !album.Songs.Any(as2 => as2.Id == s.Id)))
                                {
                                    <p class="add-song-empty">All your songs are already in this album.</p>
                                }
                            </div>
                        </div>
                    }

                    @if (album.Songs.Count == 0)
                    {
                        <p class="empty-text empty-text--indent">No songs in this album yet.</p>
                    }
                    else
                    {
                        <div class="song-list">
                            @for (int i = 0; i < album.Songs.Count; i++)
                            {
                                var song = album.Songs[i];
                                var index = i;
                                <div class="song-row">
                                    <span class="song-index">@(index + 1)</span>
                                    <div class="song-info">
                                        <span class="song-name">@song.Name</span>
                                        @if (song.Duration > 0)
                                        {
                                            var ts = TimeSpan.FromSeconds(song.Duration);
                                            <span class="song-duration">@($"{(int)ts.TotalMinutes}:{ts.Seconds:D2}")</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </section>

</div>

@code {
    private List<Album> albums = [];
    private List<Song> allSongs = [];
    private bool isLoading = true;

    private bool showCreateAlbum = false;
    private string newAlbumTitle = "";
    private bool isCreatingAlbum = false;

    private bool showUploadForm = false;
    private string newSongName = "";
    private IBrowserFile? selectedFile;
    private string? uploadError;
    private string? uploadSuccess;
    private bool isUploading = false;

    private int? addSongForAlbumId = null;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.ArtistId == null) return;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        var artistId = AuthState.ArtistId!.Value;
        albums = await ArtistService.GetArtistAlbumsAsync(artistId);
        allSongs = await ArtistService.GetArtistSongsAsync(artistId);
        isLoading = false;
    }

    private void ToggleCreateAlbum()
    {
        showCreateAlbum = !showCreateAlbum;
        newAlbumTitle = "";
    }

    private async Task CreateAlbum()
    {
        if (string.IsNullOrWhiteSpace(newAlbumTitle) || isCreatingAlbum) return;
        isCreatingAlbum = true;
        var album = await AlbumService.CreateAlbumAsync(newAlbumTitle.Trim());
        if (album != null)
        {
            showCreateAlbum = false;
            newAlbumTitle = "";
            await LoadData();
        }
        isCreatingAlbum = false;
    }

    private async Task HandleAlbumKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateAlbum();
    }

    private async Task DeleteAlbum(int albumId)
    {
        await AlbumService.DeleteAlbumAsync(albumId);
        await LoadData();
    }

    private void ToggleAddSong(int albumId)
    {
        addSongForAlbumId = addSongForAlbumId == albumId ? null : albumId;
    }

    private async Task AddSongToAlbum(int albumId, int songId)
    {
        await AlbumService.AddSongToAlbumAsync(albumId, songId);
        addSongForAlbumId = null;
        await LoadData();
    }

    private void ToggleUploadForm()
    {
        showUploadForm = !showUploadForm;
        newSongName = "";
        selectedFile = null;
        uploadError = null;
        uploadSuccess = null;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        uploadError = null;
    }

    private async Task UploadSong()
    {
        uploadError = null;
        uploadSuccess = null;

        if (string.IsNullOrWhiteSpace(newSongName))
        {
            uploadError = "Song name is required.";
            return;
        }
        if (selectedFile == null)
        {
            uploadError = "Please select an MP3 file.";
            return;
        }
        if (!selectedFile.Name.EndsWith(".mp3", StringComparison.OrdinalIgnoreCase))
        {
            uploadError = "Only MP3 files are supported.";
            return;
        }
        if (AuthState.ArtistId == null) return;

        isUploading = true;
        var song = await SongService.UploadSongAsync(newSongName.Trim(), selectedFile, AuthState.ArtistId.Value);
        isUploading = false;

        if (song != null)
        {
            uploadSuccess = $"\"{song.Name}\" uploaded successfully.";
            newSongName = "";
            selectedFile = null;
            await LoadData();
        }
        else
        {
            uploadError = "Upload failed. Please try again.";
        }
    }
}
