@page "/register"
@layout Layout.LoginLayout
@using Stopify.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Nav

<div class="login-container">
    <div class="login-left">
        <div class="login-content">
            <img src="images/stopify_logo_black.png" alt="Stopify" class="login-logo" />
            <h1 class="login-title">New here?</h1>
            <p class="login-subtitle">Please fill in the following credentials to register your account and make the registration complete.</p>

            <div class="account-toggle">
                <button class="toggle-btn @(isArtist ? "" : "active")" @onclick="() => isArtist = false">User</button>
                <button class="toggle-btn @(isArtist ? "active" : "")" @onclick="() => isArtist = true">Artist</button>
            </div>

            <form class="register-form" @onsubmit="HandleRegister" @onsubmit:preventDefault>
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-input @(errorMessage != null ? "input-error" : "")" placeholder="jouw gebruikersnaam" @bind="username" @bind:event="oninput" />
                </div>

                @if (isArtist)
                {
                    <div class="form-group">
                        <label class="form-label">Artist name</label>
                        <input type="text" class="form-input @(errorMessage != null ? "input-error" : "")" placeholder="jouw artiestennaam" @bind="artistName" @bind:event="oninput" />
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-input @(errorMessage != null ? "input-error" : "")" placeholder="jouw@email.nl" @bind="email" @bind:event="oninput" />
                </div>

                <div class="form-group">
                    <label class="form-label">Wachtwoord</label>
                    <input type="password" class="form-input @(errorMessage != null ? "input-error" : "")" placeholder="••••••••" @bind="password" @bind:event="oninput" />
                </div>

                <div class="form-group">
                    <label class="form-label">Herhaal wachtwoord</label>
                    <input type="password" class="form-input @(errorMessage != null ? "input-error" : "")" placeholder="••••••••" @bind="repeatPassword" @bind:event="oninput" />
                </div>

                @if (errorMessage != null)
                {
                    <p class="error-message">@errorMessage</p>
                }

                <button type="submit" class="login-button" disabled="@isLoading">
                    @if (isLoading) { <span>Bezig...</span> } else { <span>Register</span> }
                </button>

                <button type="button" class="login-button secondary-button" @onclick='() => Nav.NavigateTo("/login")'>
                    Login
                </button>
            </form>
        </div>
    </div>

    <div class="login-right">
        <img src="images/stopify_login_image_right.png" alt="" class="login-right-image" />
    </div>
</div>

@code {
    private string username = "";
    private string email = "";
    private string password = "";
    private string repeatPassword = "";
    private string artistName = "";
    private bool isArtist = false;
    private string? errorMessage;
    private bool isLoading;

    private async Task HandleRegister()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Vul alle velden in.";
            return;
        }

        if (password != repeatPassword)
        {
            errorMessage = "Wachtwoorden komen niet overeen.";
            return;
        }

        if (isArtist && string.IsNullOrWhiteSpace(artistName))
        {
            errorMessage = "Vul een artiestennaam in.";
            return;
        }

        isLoading = true;
        try
        {
            if (isArtist)
                await AuthService.RegisterArtistAsync(username, artistName, email, password);
            else
                await AuthService.RegisterUserAsync(username, email, password);

            Nav.NavigateTo("/login");
        }
        catch
        {
            errorMessage = "Registratie mislukt. Probeer een ander e-mailadres.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
