@page "/playlists"
@using Stopify.Models.Music
@using Stopify.Services.Music
@using Stopify.Services.Auth
@inject IPlaylistService PlaylistService
@inject IAuthStateService AuthState

<div class="hero">
    <div class="hero-content">
        <div class="hero-title-row">
            <h1 class="hero-title">Playlists</h1>
            <button class="hero-create-btn" @onclick="ToggleCreateForm">+ New Playlist</button>
        </div>
        <p class="hero-subtitle">@playlists.Count playlists</p>
        @if (showCreateForm)
        {
            <div class="hero-create-form">
                <input class="hero-create-input" type="text" placeholder="Playlist name..." @bind="newPlaylistTitle" @bind:event="oninput" @onkeydown="HandleCreateKeyDown" />
                <button class="hero-create-submit" @onclick="HandleCreatePlaylist" disabled="@isCreating">+</button>
            </div>
        }
    </div>
</div>

<div class="playlists-section">
    <p class="section-label">All playlists</p>

    @if (playlists.Count == 0)
    {
        <p class="text-white-50">No playlists found.</p>
    }
    else
    {
        <div class="playlist-grid">
            @foreach (var playlist in playlists)
            {
                <a href="/playlists/@playlist.Id" class="playlist-card">
                    <span class="playlist-card-title">@playlist.Title</span>
                </a>
            }
        </div>
    }
</div>

@code {
    private List<Playlist> playlists = [];
    private string newPlaylistTitle = "";
    private bool isCreating = false;
    private bool showCreateForm = false;

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated) return;
        playlists = (await PlaylistService.GetUserPlaylistsAsync()).OrderByDescending(p => p.Id).ToList();
    }

    private async Task HandleCreatePlaylist()
    {
        if (string.IsNullOrWhiteSpace(newPlaylistTitle) || isCreating) return;
        isCreating = true;
        await PlaylistService.CreatePlaylistAsync(newPlaylistTitle.Trim());
        newPlaylistTitle = "";
        showCreateForm = false;
        playlists = (await PlaylistService.GetUserPlaylistsAsync()).OrderByDescending(p => p.Id).ToList();
        isCreating = false;
        StateHasChanged();
    }

    private async Task HandleCreateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleCreatePlaylist();
    }
}
