@using Stopify.Services.Player
@using Stopify.Services.Session
@inject IPlayerStateService Player
@inject ISessionStateService SessionState
@inject ISessionSyncService SessionSync
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<audio id="stopify-audio" style="display:none;"></audio>

@if (showQueue && Player.Queue.Count > 0)
{
    <div class="queue-panel">
        <div class="queue-header">
            <span class="queue-title">Queue</span>
            <button class="queue-close-btn" @onclick="() => showQueue = false">✕</button>
        </div>
        <div class="queue-list">
            @for (int i = 0; i < Player.Queue.Count; i++)
            {
                var song = Player.Queue[i];
                var index = i;
                <div class="queue-item">
                    <span class="queue-item-index">@(index + 1)</span>
                    <span class="queue-item-name">@song.Name</span>
                    <button class="queue-remove-btn" @onclick="() => Player.RemoveFromQueue(index)" title="Remove">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (Player.CurrentSong != null)
{
    <div class="player-bar">
        <div class="player-main-row">
            <div class="player-song">
                <div class="player-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="20" height="20">
                        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                    </svg>
                </div>
                <div class="player-song-text">
                    <span class="player-song-name">@Player.CurrentSong.Name</span>
                    @if (audioError != null)
                    {
                        <span class="player-error">@audioError</span>
                    }
                </div>
            </div>

            <div class="player-controls">
                <button class="player-skip-btn" @onclick="Player.SkipPrevious" disabled="@(!Player.HasPrevious)" title="Previous">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                        <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
                    </svg>
                </button>

                <button class="player-btn" @onclick="() => TogglePlay()" disabled="@isBuffering">
                    @if (isBuffering)
                    {
                        <span class="player-spinner"></span>
                    }
                    else if (Player.IsPlaying)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
                            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
                            <path d="M8 5v14l11-7z"/>
                        </svg>
                    }
                </button>

                <button class="player-skip-btn" @onclick="Player.SkipNext" disabled="@(!Player.HasNext)" title="Next">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                        <path d="M6 18l8.5-6L6 6v12zm2.5-6 5.5 4V8l-5.5 4zM16 6h2v12h-2z"/>
                    </svg>
                </button>
            </div>

            <div class="player-right">
                @if (SessionState.CurrentSessionId != null && !SessionState.IsHost && !SessionSync.IsSynced)
                {
                    <button class="player-sync-btn" @onclick="() => SessionSync.ResyncAsync()" title="Sync with host">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                            <path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/>
                        </svg>
                        <span class="player-sync-label">Sync</span>
                    </button>
                }
                <div class="player-volume">
                    <button class="player-volume-btn" @onclick="ToggleMute" title="@(_isMuted ? "Unmute" : "Mute")">
                        @if (_isMuted || _volume == 0)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                            </svg>
                        }
                        else if (_volume < 0.5)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M18.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM5 9v6h4l5 5V4L9 9H5z"/>
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                            </svg>
                        }
                    </button>
                    <input type="range" class="player-volume-slider"
                           min="0" max="100" step="1"
                           value="@(_isMuted ? 0 : (int)(_volume * 100))"
                           style="--vol-pct: @VolumePct%"
                           @oninput="HandleVolumeChange" />
                </div>
                <button class="player-queue-btn @(showQueue ? "player-queue-btn--active" : "")" @onclick="ToggleQueue" title="Queue">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                        <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
                    </svg>
                    @if (Player.Queue.Count > 0)
                    {
                        <span class="queue-badge">@Player.Queue.Count</span>
                    }
                </button>
            </div>
        </div>

        <div class="player-progress-row">
            <span class="player-time">@FormatTime(_currentTime)</span>
            <input type="range" class="player-seek"
                   min="0" max="@(_duration > 0 ? _duration.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) : "1")"
                   step="1"
                   value="@((int)_currentTime)"
                   style="--seek-pct: @SeekFillPct%"
                   @oninput="HandleSeek" />
            <span class="player-time">@FormatTime(_duration)</span>
        </div>
    </div>
}

@code {
    private int? _loadedSongId;
    private int _loadedPlayVersion = -1;
    private bool _isRendered;
    private bool isBuffering;
    private string? audioError;
    private bool showQueue;
    private DotNetObjectReference<PlayerBar>? _dotnetRef;
    private double _currentTime;
    private double _duration;
    private double _volume = 1.0;
    private bool _isMuted;

    private string VolumePct => _isMuted || _volume == 0
        ? "0"
        : (_volume * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

    private string SeekFillPct => _duration > 0
        ? (_currentTime / _duration * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
        : "0";

    private static string FormatTime(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";
    }

    protected override void OnInitialized()
    {
        Player.OnChange += OnPlayerChanged;
        Player.OnQueueChange += OnQueueChanged;
        SessionSync.SeekRequested += OnSeekRequested;
        SessionSync.OnStateChanged += OnSyncStateChanged;
    }

    private void OnSyncStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _isRendered = true;
        _dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("stopifyPlayer.init", _dotnetRef);
    }

    private void OnPlayerChanged()
    {
        InvokeAsync(async () =>
        {
            if (_isRendered) await SyncAudio();
            StateHasChanged();
        });
    }

    private void OnQueueChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SyncAudio()
    {
        if (Player.CurrentSong == null)
        {
            await JS.InvokeVoidAsync("stopifyPlayer.stop");
            _loadedSongId = null;
            isBuffering = false;
        }
        else if (Player.IsPlaying)
        {
            if (_loadedSongId != Player.CurrentSong.Id || _loadedPlayVersion != Player.PlayVersion)
            {
                isBuffering = true;
                audioError = null;
                _currentTime = 0;
                _duration = 0;
                StateHasChanged();

                try
                {
                    var response = await Http.GetAsync($"api/stream/{Player.CurrentSong.Id}");
                    if (response.IsSuccessStatusCode)
                    {
                        var bytes = await response.Content.ReadAsByteArrayAsync();
                        var dataUrl = $"data:audio/mpeg;base64,{Convert.ToBase64String(bytes)}";
                        await JS.InvokeVoidAsync("stopifyPlayer.play", dataUrl);
                        _loadedSongId = Player.CurrentSong.Id;
                        _loadedPlayVersion = Player.PlayVersion;
                    }
                    else
                    {
                        audioError = $"HTTP {(int)response.StatusCode}";
                    }
                }
                catch (Exception ex)
                {
                    audioError = ex.Message;
                }

                isBuffering = false;
            }
            else
            {
                await JS.InvokeVoidAsync("stopifyPlayer.resume");
            }
        }
        else
        {
            await JS.InvokeVoidAsync("stopifyPlayer.pause");
        }
    }

    [JSInvokable]
    public void OnAudioEnded()
    {
        if (SessionState.CurrentSessionId != null && SessionState.IsHost)
            InvokeAsync(SessionSync.SongEndedAsync);
        else
            Player.SkipNext();
    }

    [JSInvokable]
    public void OnAudioError(string message)
    {
        isBuffering = false;
        audioError = message;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnTimeUpdate(double currentTime, double duration)
    {
        _currentTime = currentTime;
        _duration = duration;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleSeek(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var time))
        {
            _currentTime = time;
            await JS.InvokeVoidAsync("stopifyPlayer.seek", time);
            if (SessionState.CurrentSessionId != null && SessionState.IsHost)
                await SessionSync.SeekAsync(time);
        }
    }

    private async Task ToggleMute()
    {
        _isMuted = !_isMuted;
        await JS.InvokeVoidAsync("stopifyPlayer.setMuted", _isMuted);
    }

    private async Task HandleVolumeChange(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var val))
        {
            _volume = val / 100.0;
            if (_isMuted)
            {
                _isMuted = false;
                await JS.InvokeVoidAsync("stopifyPlayer.setMuted", false);
            }
            await JS.InvokeVoidAsync("stopifyPlayer.setVolume", _volume);
        }
    }

    private async Task TogglePlay()
    {
        if (Player.IsPlaying)
        {
            Player.Pause();
            if (SessionState.CurrentSessionId != null)
            {
                if (SessionState.IsHost)
                    await SessionSync.PauseAsync(_currentTime);
                else
                    SessionSync.SetOutOfSync();
            }
        }
        else
        {
            Player.Resume();
            if (SessionState.CurrentSessionId != null)
            {
                if (SessionState.IsHost)
                    await SessionSync.PlayAsync(_currentTime);
                else
                    SessionSync.SetOutOfSync();
            }
        }
    }

    private void OnSeekRequested(double position)
    {
        InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("stopifyPlayer.seek", position);
            _currentTime = position;
            StateHasChanged();
        });
    }

    private void ToggleQueue()
    {
        showQueue = !showQueue;
    }

    public void Dispose()
    {
        Player.OnChange -= OnPlayerChanged;
        Player.OnQueueChange -= OnQueueChanged;
        SessionSync.SeekRequested -= OnSeekRequested;
        SessionSync.OnStateChanged -= OnSyncStateChanged;
        _dotnetRef?.Dispose();
    }
}