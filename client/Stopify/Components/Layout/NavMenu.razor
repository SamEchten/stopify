@using Stopify.Services.Music
@using Stopify.Services.Auth
@using Stopify.Models.Music
@inject IPlaylistService PlaylistService
@inject IAuthStateService AuthState

<div class="top-row p-3 m-auto ">
    <div class="container-fluid">
        <img src="images/logo.png" width="140px"/>
    </div>
</div>

<div class="nav-scrollable px-5 py-4">
	<nav class="d-flex flex-column gap-4">
		<div class="col gap-2">
			<div class="nav-item">
				<NavLink class="d-flex flex-row text-light gap-3 text-decoration-none" href="/">
					<span class="house-icon"></span> Home
				</NavLink>
			</div>
			<div class="nav-item">
				<NavLink class="d-flex flex-row text-light gap-3 text-decoration-none" href="/playlists">
					<span class="music-list-icon"></span> Playlists
				</NavLink>
			</div>
			<div class="nav-item">
				<div class="d-flex flex-row text-light gap-3 nav-clickable" @onclick="ToggleCreateForm">
					<span class="create-icon"></span> Create playlist
				</div>
				@if (showCreateForm)
				{
					<div class="create-playlist-form d-flex flex-row gap-2 mt-2">
						<input class="create-playlist-input" type="text" placeholder="Playlist name..." @bind="newPlaylistTitle" @bind:event="oninput" @onkeydown="HandleCreateKeyDown" />
						<button class="create-playlist-btn" @onclick="HandleCreatePlaylist" disabled="@isCreating">+</button>
					</div>
				}
			</div>
			<div class="nav-item">
				<NavLink class="d-flex flex-row text-light gap-3 text-decoration-none" href="/current-session">
					<span class="persons-icon"></span> Current session
				</NavLink>
			</div>
		</div>

		<div class="d-flex flex-column gap-2 text-white">
			<small class="playlist-label">Your playlists</small>
			<hr class="playlist-divider"/>
			@foreach (var playlist in playlists)
			{
				<a href="/playlists/@playlist.Id" class="nav-playlist-item">@playlist.Title</a>
			}
		</div>

		<div class="mt-auto d-flex flex-column gap-2 text-white">
			<div class="nav-item">
				<NavLink href="/profile" class="d-flex flex-row text-light gap-3 text-decoration-none">
					<span class="profile-icon"></span>
					Profile
				</NavLink>
			</div>
			<div class="nav-item">
				<NavLink href="/logout" class="d-flex flex-row text-light gap-3 text-decoration-none">
					<span class="logout-icon"></span>
					Log out
				</NavLink>
			</div>
		</div>
	</nav>

</div>

@code {
    private List<Playlist> playlists = [];
    private string newPlaylistTitle = "";
    private bool isCreating = false;
    private bool showCreateForm = false;

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated) return;
        await LoadPlaylists();
    }

    private async Task LoadPlaylists()
    {
        var all = await PlaylistService.GetUserPlaylistsAsync();
        playlists = all.OrderByDescending(p => p.Id).Take(5).ToList();
    }

    private async Task HandleCreatePlaylist()
    {
        if (string.IsNullOrWhiteSpace(newPlaylistTitle) || isCreating) return;
        isCreating = true;
        await PlaylistService.CreatePlaylistAsync(newPlaylistTitle.Trim());
        newPlaylistTitle = "";
        showCreateForm = false;
        await LoadPlaylists();
        isCreating = false;
    }

    private async Task HandleCreateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleCreatePlaylist();
    }

}
