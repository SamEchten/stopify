@using Stopify.Models.Music
@using Stopify.Services.Music
@using Stopify.Services.Auth
@inject ISongService SongService
@inject IPlaylistService PlaylistService
@inject IAuthStateService AuthState
@implements IDisposable

<div class="top-bar">
    <div class="search-container">
        <div class="search-wrap">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 width="16" height="16">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text"
                   class="search-input"
                   placeholder="Search songs..."
                   value="@searchQuery"
                   @oninput="OnSearchInput" />
        </div>

        @if (dropdownVisible)
        {
            <div class="search-dropdown" @onclick="CloseMenu">
                @if (searching)
                {
                    <p class="dropdown-message">Searching...</p>
                }
                else if (results.Count == 0)
                {
                    <p class="dropdown-message">No songs found.</p>
                }
                else
                {
                    @foreach (var song in results)
                    {
                        <div class="song-row">
                            <button class="song-play-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="18" height="18">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                            </button>
                            <div class="song-info">
                                <span class="song-name">@song.Name</span>
                            </div>
                            <div class="song-menu-wrap">
                                <button class="dots-btn" @onclick="() => ToggleMenu(song.Id)" @onclick:stopPropagation>
                                    <span class="dot"></span>
                                    <span class="dot"></span>
                                    <span class="dot"></span>
                                </button>
                                @if (openMenuId == song.Id)
                                {
                                    <div class="floating-menu" @onclick:stopPropagation>
                                        @if (showingPlaylistsForSong == song.Id)
                                        {
                                            <div class="menu-back" @onclick="() => showingPlaylistsForSong = null">← Back</div>
                                            @if (playlists.Count == 0)
                                            {
                                                <p class="floating-menu-placeholder">No playlists found.</p>
                                            }
                                            @foreach (var pl in playlists)
                                            {
                                                <button class="menu-item" @onclick="() => AddToPlaylist(song.Id, pl.Id)">@pl.Title</button>
                                            }
                                        }
                                        else
                                        {
                                            <button class="menu-item" @onclick="() => showingPlaylistsForSong = song.Id">Add to playlist</button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="dropdown-backdrop" @onclick="CloseDropdown"></div>
        }
    </div>
</div>

@code {
    private string searchQuery = "";
    private List<Song> results = [];
    private List<Playlist> playlists = [];
    private bool dropdownVisible;
    private bool searching;
    private int? openMenuId;
    private int? showingPlaylistsForSong;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.IsAuthenticated)
            playlists = await PlaylistService.GetUserPlaylistsAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";

        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            dropdownVisible = false;
            results = [];
            return;
        }

        dropdownVisible = true;
        searching = true;
        openMenuId = null;
        showingPlaylistsForSong = null;

        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, _cts.Token);
            results = await SongService.SearchSongsAsync(searchQuery);
        }
        catch (TaskCanceledException) { }
        finally
        {
            searching = false;
        }
    }

    private void ToggleMenu(int id)
    {
        if (openMenuId == id) { openMenuId = null; showingPlaylistsForSong = null; }
        else { openMenuId = id; showingPlaylistsForSong = null; }
    }

    private void CloseMenu() { openMenuId = null; showingPlaylistsForSong = null; }

    private void CloseDropdown()
    {
        dropdownVisible = false;
        searchQuery = "";
        results = [];
        openMenuId = null;
        showingPlaylistsForSong = null;
    }

    private async Task AddToPlaylist(int songId, int playlistId)
    {
        await PlaylistService.AddSongToPlaylistAsync(playlistId, songId);
        CloseMenu();
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
